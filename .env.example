# Mudholkars and Co — Environment Variables
# Copy this to .env and fill in your secrets
# NEVER commit .env to git (it's in .gitignore)

# Groww Trading API (₹499/month from https://groww.in/user/profile/trading-apis)
GROWW_API_KEY=your_groww_api_key_here
GROWW_API_SECRET=your_groww_secret_here

# Telegram Bot (free from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Portfolio config
INITIAL_CAPITAL=1000000
MAX_POSITIONS=5
MAX_RISK_PCT=2.0
